---
interface Props {
  description: string;
  title?: string;
}

const {
  description,
  title = "Openbird | Local-first macOS activity journal",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/png" href="/openbird.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-banner-wrap">
      <p class="site-banner">
        Planned for Char:
        Openbird is being developed for integration into
        <a href="https://char.com">Char</a>
        as a feature.
      </p>
    </div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --text: #111111;
    --muted: #505050;
    --line: #d4d4d4;
    --link: #165dff;
    --banner-text: #5a2a00;
    --banner-line: #f0c28d;
    --banner-bg: #fff4e7;
    --code-text: #16314f;
    --code-line: #dbe4f0;
    --code-bg: #f5f8fc;
    --body-line-height: 1.58;
    --title-size: 1.85rem;
    --title-line-height: 1.25;
    --subtitle-size: 0.92rem;
    --header-gap: 6px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 10px auto;
    min-width: 320px;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 15px;
    line-height: var(--body-line-height);
    color: var(--text);
    background: #ffffff;
  }

  a {
    color: var(--link);
    text-underline-offset: 0.16em;
  }

  a:hover {
    text-decoration-thickness: 2px;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p,
  ul,
  ol,
  hr {
    margin: 0 0 16px;
  }

  h1,
  h2,
  h3 {
    font-weight: 600;
    line-height: 1.25;
  }

  h1 {
    font-size: var(--title-size);
  }

  h2 {
    font-size: 1.28rem;
  }

  h3 {
    font-size: 0.96rem;
  }

  hr {
    border: 0;
    border-top: 1px solid var(--line);
  }

  ul,
  ol {
    padding-left: 22px;
  }

  li {
    margin-bottom: 8px;
  }

  code,
  pre,
  .mono {
    font-family:
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      "Liberation Mono",
      monospace;
    font-size: 0.92em;
  }

  code {
    padding: 0.12rem 0.38rem;
    border: 1px solid var(--code-line);
    border-radius: 6px;
    background: var(--code-bg);
    color: var(--code-text);
  }

  pre {
    overflow-x: auto;
    padding: 14px 16px;
    border: 1px solid var(--code-line);
    border-radius: 10px;
    background: linear-gradient(180deg, #f8fbff 0%, #f3f7fb 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  pre code {
    display: block;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: inherit;
  }

  .page {
    max-width: 700px;
    margin-right: 16px;
    margin-left: 22px;
  }

  .site-banner-wrap {
    max-width: 700px;
    margin: 0 16px 18px 22px;
  }

  .site-banner {
    margin: 0;
    padding: 10px 12px;
    border: 1px solid var(--banner-line);
    border-radius: 10px;
    background: var(--banner-bg);
    color: var(--banner-text);
    font-size: 0.92rem;
  }

  .page > h2 {
    margin-top: 32px;
  }

  .header {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 12px;
    row-gap: var(--header-gap);
    align-items: start;
    margin-bottom: 20px;
  }

  .header-icon {
    grid-row: 1 / span 2;
    width: auto;
    height: calc(
      (var(--title-size) * var(--title-line-height)) +
      (var(--subtitle-size) * var(--body-line-height)) +
      var(--header-gap)
    );
  }

  .header h1 {
    grid-column: 2;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.18em;
    margin-bottom: 0;
  }

  .title-tag {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    font-size: 0.62em;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .header p {
    grid-column: 2;
    margin-bottom: 0;
    color: var(--muted);
    font-size: var(--subtitle-size);
  }

  .muted {
    color: var(--muted);
  }

  .small {
    font-size: 0.88rem;
  }

  @media (min-width: 768px) {
    body {
      margin-top: 60px;
      margin-bottom: 40px;
    }

    .page {
      margin-left: 80px;
      margin-right: auto;
    }

    .site-banner-wrap {
      margin-left: 80px;
      margin-right: auto;
    }
  }
</style>
