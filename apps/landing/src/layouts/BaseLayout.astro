---
interface Props {
  description: string;
  title?: string;
}

const {
  description,
  title = "Openbird | Local-first macOS activity journal",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/png" href="/openbird.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --text: #111111;
    --muted: #505050;
    --line: #d4d4d4;
    --link: #165dff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 10px auto;
    min-width: 320px;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 15px;
    line-height: 1.58;
    color: var(--text);
    background: #ffffff;
  }

  a {
    color: var(--link);
    text-underline-offset: 0.16em;
  }

  a:hover {
    text-decoration-thickness: 2px;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p,
  ul,
  ol,
  hr {
    margin: 0 0 16px;
  }

  h1,
  h2,
  h3 {
    font-weight: 600;
    line-height: 1.25;
  }

  h1 {
    font-size: 1.85rem;
  }

  h2 {
    font-size: 1.28rem;
  }

  h3 {
    font-size: 0.96rem;
  }

  hr {
    border: 0;
    border-top: 1px solid var(--line);
  }

  ul,
  ol {
    padding-left: 22px;
  }

  li {
    margin-bottom: 8px;
  }

  code,
  pre {
    font-family:
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      "Liberation Mono",
      monospace;
    font-size: 0.92em;
  }

  .page {
    max-width: 700px;
    margin-right: 16px;
    margin-left: 22px;
  }

  .header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 8px;
  }

  .header-icon {
    width: 88px;
    height: auto;
    flex: 0 0 auto;
  }

  .header-copy h1 {
    margin-bottom: 4px;
  }

  .header-copy p {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .muted {
    color: var(--muted);
  }

  .small {
    font-size: 0.88rem;
  }

  @media (min-width: 768px) {
    body {
      margin-top: 60px;
      margin-bottom: 40px;
    }

    .page {
      margin-left: 80px;
      margin-right: auto;
    }

    .header-icon {
      width: 104px;
    }
  }
</style>
