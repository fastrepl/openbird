---
interface Props {
  description: string;
  title?: string;
}

const {
  description,
  title = "Openbird | Local-first macOS activity journal",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 18px;
    line-height: 1.55;
    color: #111111;
    background: #ffffff;
  }

  a {
    color: #0000ee;
  }

  a:visited {
    color: #551a8b;
  }

  img {
    display: block;
    max-width: 100%;
  }

  main {
    display: block;
  }

  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 24px 16px 64px;
  }

  header,
  section,
  footer {
    display: block;
  }

  h1,
  h2,
  h3,
  p,
  ul,
  ol,
  pre {
    margin: 0 0 16px;
  }

  h1,
  h2,
  h3 {
    font-family: "Times New Roman", Times, serif;
    font-weight: 700;
    line-height: 1.2;
  }

  h1 {
    font-size: 2.4rem;
  }

  h2 {
    font-size: 1.6rem;
    margin-top: 32px;
  }

  h3 {
    font-size: 1.15rem;
  }

  hr {
    margin: 24px 0;
    border: 0;
    border-top: 1px solid #cccccc;
  }

  ul,
  ol {
    padding-left: 24px;
  }

  li {
    margin-bottom: 8px;
  }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    padding-left: 20px;
  }

  pre,
  code {
    font-family: "Courier New", Courier, monospace;
    font-size: 0.95em;
  }

  pre {
    overflow-x: auto;
    padding: 12px;
    border: 1px solid #cccccc;
    background: #f7f7f7;
  }

  .muted {
    color: #444444;
  }

  .small {
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    body {
      font-size: 17px;
    }

    h1 {
      font-size: 2rem;
    }
  }
</style>
